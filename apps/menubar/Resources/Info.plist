<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>SyncCast</string>
    <key>CFBundleDisplayName</key>
    <string>SyncCast</string>
    <key>CFBundleIdentifier</key>
    <string>io.syncast.menubar</string>
    <key>CFBundleVersion</key>
    <string>0.1.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0-alpha</string>
    <key>CFBundleExecutable</key>
    <string>SyncCastMenuBar</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- Hide from Dock — menubar-only -->
    <key>LSUIElement</key>
    <true/>
    <!-- System audio capture currently defaults to ScreenCaptureKit. Tap
         mode should use the system-audio capture permission instead of
         Screen Recording once fully shipped. The microphone is used only by
         explicit diagnostic measurement flows; normal playback does not
         open the mic or emit calibration tones. -->
    <key>NSAudioCaptureUsageDescription</key>
    <string>SyncCast captures system audio so it can play the same audio through the output devices you enable.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>SyncCast can use the microphone only when you explicitly run diagnostics to compare room audio timing. Normal playback and Stereo mode do not use the microphone or play calibration tones.</string>
    <!-- Required since macOS Sequoia for any app that browses mDNS / Bonjour
         services. Without this key the OS denies the browse silently. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>SyncCast browses the local network for AirPlay 2 receivers (HomePod, Xiaomi Sound, other Macs) so you can choose them as audio outputs.</string>
    <!-- Bonjour service types we actively browse for -->
    <key>NSBonjourServices</key>
    <array>
        <string>_airplay._tcp</string>
        <string>_raop._tcp</string>
    </array>
    <!-- We start child processes (sidecar + OwnTone) and read/write under
         ~/Library/Application Support; no sandbox entitlements requested. -->
    <key>NSHumanReadableCopyright</key>
    <string>© 2026 SyncCast Contributors. MIT license. Bundles OwnTone (GPL-2.0).</string>
</dict>
</plist>
